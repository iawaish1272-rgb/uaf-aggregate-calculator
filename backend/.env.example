# Copy this file to .env and fill in your real values (never commit .env to GitHub)

# Your MongoDB connection string (MongoDB Atlas or the same one you use for iAWAiSH)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/aggregate-calculator

# Password required to view the admin dashboard.
# Recommended: change this to something only you know, and set it here
# instead of leaving the fallback hardcoded in routes/submissions.js
ADMIN_PASSWORD=421806

# Railway sets this automatically — you usually don't need to set it yourself
PORT=5000
